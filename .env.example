# Database
TALKDB_DEFAULT_DB="sqlite:///./data/example.db"

# LLM provider (via LiteLLM)
TALKDB_LLM_MODEL="claude-sonnet-4-6"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# Embedding model
TALKDB_EMBEDDING_MODEL="text-embedding-3-small"

# Vector store
TALKDB_VECTOR_STORE="chroma"
TALKDB_CHROMA_PATH="./data/chroma"

# Validation
TALKDB_CONFIDENCE_THRESHOLD=50
TALKDB_QUERY_TIMEOUT=10
TALKDB_DUAL_PATH_ENABLED=false

# Insight agent
TALKDB_INSIGHT_ENABLED=false
TALKDB_CHART_FORMAT="png"

# Watchdog
TALKDB_WATCHDOG_ENABLED=false
TALKDB_WATCHDOG_DB="./data/watchdog.sqlite"

# Semantic model
TALKDB_SEMANTIC_MODEL_PATH="./semantic_models/"

# Community registry
TALKDB_REGISTRY_URL="https://registry.talkdb.dev"
TALKDB_REGISTRY_PACKAGES_PATH="./data/packages/"

# Conversation
TALKDB_SESSION_TTL_MINUTES=60
TALKDB_SESSION_STORE="memory"

# Server
TALKDB_HOST="0.0.0.0"
TALKDB_PORT=8000
